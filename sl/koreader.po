#: frontend/apps/reader/modules/readerlink.lua:510
#: frontend/ui/data/css_tweaks.lua:651
msgid "Links"
msgstr "Povezave"

#: frontend/apps/reader/modules/readerlink.lua:513
msgid "Tap to follow links"
msgstr "Tapni za sledenje povezavam"

#: frontend/apps/reader/modules/readerlink.lua:519
msgid "Tap on links to follow them."
msgstr "Tapni na povezave, da jim slediš."

#: frontend/apps/reader/modules/readerlink.lua:522
msgid "Ignore external links on tap"
msgstr "Prezri zunanje povezave ob tapu"

#: frontend/apps/reader/modules/readerlink.lua:529
msgid ""
"Ignore taps on external links. Useful with Wikipedia EPUBs to make page "
"turning easier.\n"
"You can still follow them from the dictionary window or the selection menu "
"after holding on them."
msgstr ""
"Prezri tape na zunanje povezave. Uporabno pri Wikipedijinih EPUB-ih za lažje "
"obračanje strani.\n"
"Še vedno jim lahko slediš prek okna slovarja ali izbirnega menija, če jih "
"držiš."

#: frontend/apps/reader/modules/readerlink.lua:535
msgid "Swipe to go back"
msgstr "Potegni za nazaj"

#: frontend/apps/reader/modules/readerlink.lua:541
msgid ""
"Swipe to the right to go back to the previous location after you have "
"followed a link. When the location stack is empty, swiping to the right "
"takes you to the previous page."
msgstr ""
"Potegni v desno za vrnitev na prejšnjo lokacijo, potem ko si sledil "
"povezavi. Če je zgodovina lokacij prazna, te poteg v desno popelje na "
"prejšnjo stran."

#: frontend/apps/reader/modules/readerlink.lua:544
msgid "Swipe to follow nearest link"
msgstr "Potegni za sledenje najbližji povezavi"

#: frontend/apps/reader/modules/readerlink.lua:550
msgid ""
"Swipe to the left to follow the link nearest to where you started the swipe. "
"This is useful when a small font is used and tapping on small links is "
"tedious."
msgstr ""
"Potegni v levo, da slediš povezavi, ki je najbližje začetku potega. To je "
"uporabno pri majhnih pisavah, kjer je težko zadeti majhne povezave s tapom."

#: frontend/apps/reader/modules/readerlink.lua:553
msgid "Ignore external links on swipe"
msgstr "Prezri zunanje povezave ob potegu"

#: frontend/apps/reader/modules/readerlink.lua:560
msgid ""
"Ignore external links near swipe. Useful with Wikipedia EPUBs to follow only "
"footnotes with swipe.\n"
"You can still follow external links from the dictionary window or the "
"selection menu after holding on them."
msgstr ""
"Prezri zunanje povezave blizu potega. Uporabno pri Wikipedijinih EPUB-ih, da "
"s potegom slediš le opombam.\n"
"Zunanjim povezavam lahko še vedno slediš prek slovarja ali z dolgim "
"pritiskom."

#: frontend/apps/reader/modules/readerlink.lua:566
msgid "Swipe to jump to latest bookmark"
msgstr "Potegni za skok na zadnji zaznamek"

#: frontend/apps/reader/modules/readerlink.lua:572
msgid ""
"Swipe to the left to go the most recently bookmarked page.\n"
"This can be useful to quickly swipe back and forth between what you are "
"reading and some reference page (for example notes, a map or a characters "
"list).\n"
"If any of the other Swipe to follow link options is enabled, this will work "
"only when the current page contains no link."
msgstr ""
"Potegni v levo za skok na nazadnje dodan zaznamek.\n"
"To je uporabno za hitro preklapljanje med branjem in referenčno stranjo "
"(npr. opombe, zemljevid ali seznam oseb).\n"
"Če je omogočena katera druga možnost potega za sledenje povezavam, bo to "
"delovalo le, če na trenutni strani ni povezav."

#: frontend/apps/reader/modules/readerlink.lua:587
msgid "Allow larger tap area around links"
msgstr "Dovoli večje območje tapa okoli povezav"

#: frontend/apps/reader/modules/readerlink.lua:594
msgid ""
"Extends the tap area around internal links. Useful with a small font where "
"tapping on small footnote links may be tedious."
msgstr ""
"Razširi območje tapa okoli notranjih povezav. Uporabno pri majhnih pisavah, "
"kjer je težko natančno tapniti na majhne povezave do opomb."

#: frontend/apps/reader/modules/readerlink.lua:747
msgid "Tap to follow links: %1"
msgstr "Tap za sledenje povezavam: %1"

#: frontend/apps/reader/modules/readerlink.lua:774
#: frontend/apps/reader/modules/readerlink.lua:781
msgid "Current location added to history."
msgstr "Trenutna lokacija dodana v zgodovino."

#: frontend/apps/reader/modules/readerlink.lua:801
msgid "Location history cleared."
msgstr "Zgodovina lokacij počiščena."

#: frontend/apps/reader/modules/readerlink.lua:847
msgid "Link from page %1"
msgstr "Povezava s strani %1"

#: frontend/apps/reader/modules/readerlink.lua:913
msgid ""
"Invalid or external link:\n"
"%1"
msgstr ""
"Neveljavna ali zunanja povezava:\n"
"%1"

#: frontend/apps/reader/modules/readerlink.lua:962
msgid ""
"Would you like to read this local document?\n"
"\n"
"%1\n"
msgstr ""
"Želiš prebrati ta lokalni dokument?\n"
"\n"
"%1\n"

#: frontend/apps/reader/modules/readerlink.lua:1620
msgid ""
"External link:\n"
"\n"
"%1"
msgstr ""
"Zunanja povezava:\n"
"\n"
"%1"

#: frontend/apps/reader/modules/readermenu.lua:194
msgid "Document settings"
msgstr "Nastavitve dokumenta"

#: frontend/apps/reader/modules/readermenu.lua:197
msgid "Reset document settings to default"
msgstr "Ponastavi nastavitve dokumenta na privzeto"

#: frontend/apps/reader/modules/readermenu.lua:201
msgid ""
"Reset current document settings to their default values?\n"
"\n"
"Reading position, highlights and bookmarks will be kept.\n"
"The document will be reloaded."
msgstr ""
"Ponastavim nastavitve trenutnega dokumenta na privzete vrednosti?\n"
"\n"
"Položaj branja, poudarki in zaznamki bodo ohranjeni.\n"
"Dokument se bo znova naložil."

#: frontend/apps/reader/modules/readermenu.lua:214
msgid "Save document settings as default"
msgstr "Shrani nastavitve dokumenta kot privzete"

#: frontend/apps/reader/modules/readermenu.lua:219
msgid "Save current document settings as default values?"
msgstr "Shranim trenutne nastavitve dokumenta kot privzete vrednosti?"

#: frontend/apps/reader/modules/readermenu.lua:225
msgid "Default settings updated"
msgstr "Privzete nastavitve posodobljene"

#: frontend/apps/reader/modules/readermenu.lua:239
#: frontend/ui/elements/page_turns.lua:170
msgid "Invert document-related dialogs"
msgstr "Invertiraj okna, povezana z dokumentom"

#: frontend/apps/reader/modules/readermenu.lua:255
#: frontend/ui/elements/page_turns.lua:186
msgid ""
"The default (★) for newly opened books is to Invert document-related "
"dialogs.\n"
"\n"
"Would you like to change it?"
msgstr ""
"Privzeto (★) za na novo odprte knjige je, da se okna, povezana z dokumentom, "
"invertirajo.\n"
"\n"
"Želiš to spremeniti?"

#: frontend/apps/reader/modules/readermenu.lua:256
#: frontend/ui/elements/page_turns.lua:187
msgid ""
"The default (★) for newly opened books is not to Invert document-related "
"dialogs.\n"
"\n"
"Would you like to change it?"
msgstr ""
"Privzeto (★) za na novo odprte knjige je, da se okna, povezana z dokumentom, "
"ne invertirajo.\n"
"\n"
"Želiš to spremeniti?"

#: frontend/apps/reader/modules/readermenu.lua:258
#: frontend/ui/elements/page_turns.lua:189
msgid "Don't invert"
msgstr "Ne invertiraj"

#: frontend/apps/reader/modules/readermenu.lua:273
#: frontend/ui/elements/page_turns.lua:204
msgid ""
"When enabled the UI direction for the Table of Contents, Book Map, and Page "
"Browser dialogs will mirror the default UI direction.\n"
"Useful when used alongside 'Invert page turn taps and swipes'."
msgstr ""
"Ko je omogočeno, bo smer uporabniškega vmesnika za kazalo, mapo knjige in "
"brskalnik strani zrcalila privzeto smer.\n"
"Uporabno v kombinaciji z možnostjo 'Invertiraj tape in potege za obračanje'."

#: frontend/apps/reader/modules/readermenu.lua:304
msgid "Do not show this book cover on sleep screen"
msgstr "Ne prikazuj platnice te knjige na zaslonu spanja"

#: frontend/apps/reader/modules/readermenu.lua:348 frontend/dispatcher.lua:59
msgid "Open previous document"
msgstr "Odpri prejšnji dokument"

#: frontend/apps/reader/modules/readermenu.lua:351
msgid "Previous: %1"
msgstr "Prejšnji: %1"

#: frontend/apps/reader/modules/readermenu.lua:362
msgid "Would you like to open the previous document: %1?"
msgstr "Želiš odpreti prejšnji dokument: %1?"

#: frontend/apps/reader/modules/readermenu.lua:439
msgid "Document menu"
msgstr "Meni dokumenta"

#: frontend/apps/reader/modules/readerpagemap.lua:91
msgid "Do you want to use them?"
msgstr "Jih želiš uporabiti?"

#: frontend/apps/reader/modules/readerpagemap.lua:281
#: frontend/apps/reader/modules/readerpagemap.lua:544
msgid "Stable page number list"
msgstr "Seznam stabilnih številk strani"

#: frontend/apps/reader/modules/readerpagemap.lua:399
msgid ""
"Publisher page numbers available.\n"
"Page numbers: %1 - %2\n"
"Source (print edition):\n"
"%3"
msgstr ""
"Založnikove številke strani so na voljo.\n"
"Številke strani: %1 - %2\n"
"Vir (tiskan izdaja):\n"
"%3"

#. @translators This and the other related ones refer to alternate page numbers provided in some EPUB books, that usually reference page numbers in a specific hardcopy edition of the book.
#: frontend/apps/reader/modules/readerpagemap.lua:419
msgid "Stable page numbers"
msgstr "Stabilne številke strani"

#: frontend/apps/reader/modules/readerpagemap.lua:440
msgid "About stable page numbers"
msgstr "O stabilnih številkah strani"

#: frontend/apps/reader/modules/readerpagemap.lua:444
msgid ""
"By default, one screen equals one page. Any change in the book's formatting "
"will therefore result in renumbering: new total pages, different chapter "
"lengths, new locations in TOC and bookmarks, etc.\n"
"\n"
"Select stable page numbers if you prefer page numbers that are independent "
"of layout settings and consistent across devices:\n"
"1. Publisher page numbers (℗): normally equivalent to a specific physical "
"edition. Only available if supplied by the publisher.\n"
"2. Characters per page: a page will be counted for this amount of characters "
"(sometimes called logical or synthetic page numbers). Use this if no "
"publisher page numbers are available or if you prefer to have consistent "
"page lengths for all books.\n"
"\n"
"Since stable page numbers can start anywhere on the screen, you can choose "
"to display them in the margin, regardless of other settings.\n"
"\n"
"'Stable page number list' shows a table of all stable page numbers and their "
"corresponding screen page numbers."
msgstr ""
"Privzeto en zaslon pomeni eno stran. Vsaka sprememba oblikovanja bo zato "
"povzročila preštevilčenje: novo skupno število strani, drugačne dolžine "
"poglavij, nove lokacije v kazalu itd.\n"
"\n"
"Izberi stabilne številke strani, če želiš številčenje, ki je neodvisno od "
"postavitve in enako na vseh napravah:\n"
"1. Založnikove številke strani (℗): običajno ustrezajo določeni fizični "
"izdaji. Na voljo le, če jih priloži založnik.\n"
"2. Znaki na stran: stran se šteje po določenem številu znakov (t.i. logične "
"ali sintetične številke strani). To uporabi, če založnikove številke niso na "
"voljo ali če želiš enako dolžino strani v vseh knjigah.\n"
"\n"
"Ker se stabilne številke strani lahko začnejo kjerkoli na zaslonu, se lahko "
"odločiš, da se prikazujejo na robu, ne glede na ostale nastavitve.\n"
"\n"
"'Seznam stabilnih številk strani' prikazuje tabelo vseh stabilnih številk in "
"njihovo ujemanje s številkami strani na zaslonu."

#: frontend/apps/reader/modules/readerpagemap.lua:461
#: frontend/apps/reader/modules/readerpagemap.lua:570
msgid "Characters per page: %1"
msgstr "Znakov na stran: %1"

#: frontend/apps/reader/modules/readerpagemap.lua:466
#: frontend/apps/reader/modules/readerpagemap.lua:575
msgid "Characters per page"
msgstr "Znakov na stran"

#: frontend/apps/reader/modules/readerpagemap.lua:492
msgid "Use publisher page numbers"
msgstr "Uporabi založnikove številke strani"

#: frontend/apps/reader/modules/readerpagemap.lua:495
msgid ""
"Use publisher page numbers?\n"
"The document will be reloaded."
msgstr ""
"Uporabim založnikove številke strani?\n"
"Dokument se bo znova naložil."

#: frontend/apps/reader/modules/readerpagemap.lua:511
#: frontend/apps/reader/modules/readerpagemap.lua:619
msgid "Use stable page numbers"
msgstr "Uporabi stabilne številke strani"

#: frontend/apps/reader/modules/readerpagemap.lua:527
#: frontend/apps/reader/modules/readerpagemap.lua:628
msgid "Show stable page numbers in margin"
msgstr "Prikaži stabilne številke strani na robu"

#. @translators This shows the <dc:source> in the EPUB that usually tells which hardcopy edition the reference page numbers refers to.
#: frontend/apps/reader/modules/readerpagemap.lua:554
msgid "Publisher page numbers source info"
msgstr "Informacije o viru založnikovih številk strani"

#: frontend/apps/reader/modules/readerpagemap.lua:565
msgid "Default settings for new books"
msgstr "Privzete nastavitve za nove knjige"

#: frontend/apps/reader/modules/readerpagemap.lua:596
msgid "Override publisher page numbers"
msgstr "Preglasi založnikove številke strani"

#: frontend/apps/reader/modules/readerpagemap.lua:609
msgid "Prompt when publisher page numbers available"
msgstr "Vprašaj, ko so na voljo založnikove številke strani"

#: frontend/apps/reader/modules/readerpagemap.lua:638
msgid "Page numbers font size: %1"
msgstr "Velikost pisave številk strani: %1"

#: frontend/apps/reader/modules/readerpagemap.lua:643
msgid "Page numbers font size"
msgstr "Velikost pisave številk strani"

#: frontend/apps/reader/modules/readerrolling.lua:313
msgid ""
"Note that this change in styles may render your bookmarks or highlights "
"invalid.\n"
"If some of them no longer appear, you can simply revert the change you just "
"made to show them again."
msgstr ""
"Upoštevaj, da lahko ta sprememba slogov razveljavi tvoje zaznamke ali "
"poudarke.\n"
"Če nekateri ne izginejo, lahko preprosto razveljaviš pravkar narejeno "
"spremembo, da se spet prikažejo."

#: frontend/apps/reader/modules/readerrolling.lua:320
msgid ""
"Styles have changed in such a way that fully reloading the document may be "
"needed for a correct rendering.\n"
"%1Do you want to reload the document?"
msgstr ""
"Slogi so se spremenili tako, da bo za pravilen prikaz morda potreben celoten "
"ponovni prenos dokumenta.\n"
"%1Želiš ponovno naložiti dokument?"

#: frontend/apps/reader/modules/readerrolling.lua:417
msgid ""
"When hide non-linear fragments is enabled, any non-linear fragments will be "
"hidden from the normal page flow. Such fragments will always remain "
"accessible through links, the table of contents and the 'Go to' dialog. This "
"only works in single-page mode."
msgstr ""
"Ko je omogočeno skrivanje nelinearnih fragmentov, bodo vsi takšni deli "
"skriti iz običajnega toka strani. Ti fragmenti bodo vedno dostopni prek "
"povezav, kazala vsebine in okna 'Skoči na'. To deluje le v načinu posameznih "
"strani."

#: frontend/apps/reader/modules/readerrolling.lua:419
msgid "Hide non-linear fragments"
msgstr "Skrij nelinearne fragmente"

#: frontend/apps/reader/modules/readerrolling.lua:432
msgid "Set default hide non-linear fragments to %1?"
msgstr "Nastavim privzeto skrivanje nelinearnih fragmentov na %1?"

#: frontend/apps/reader/modules/readerrolling.lua:433
msgid "enabled"
msgstr "omogočeno"

#: frontend/apps/reader/modules/readerrolling.lua:444
msgid "Enable partial renderings"
msgstr "Omogoči delno izrisovanje"

#: frontend/apps/reader/modules/readerrolling.lua:469
msgid ""
"With EPUB documents (having multiple fragments), text appearance adjustments "
"can be made quicker by only rendering the current chapter.\n"
"After such partial renderings, the book and KOReader are in a degraded "
"state: you can turn pages, but some info and features may be broken or "
"disabled (ie. footer info, ToC, statistics…).\n"
"To get back to a sane state, a full rendering will happen in the background, "
"get cached, and the document will be seamlessly reloaded after a brief "
"period of inactivity."
msgstr ""
"Pri dokumentih EPUB (ki imajo več fragmentov) so lahko prilagoditve videza "
"besedila hitrejše, če se izriše le trenutno poglavje.\n"
"Po takšnem delnem izrisu sta knjiga in KOReader v omejenem stanju: strani "
"lahko obračaš, vendar so nekatere informacije in funkcije lahko napačne ali "
"onemogočene (npr. noga strani, kazalo, statistika…).\n"
"Za vrnitev v normalno stanje se bo v ozadju izvedlo polno izrisovanje, "
"shranilo v predpomnilnik, dokument pa se bo neopazno ponovno naložil po "
"kratkem obdobju neaktivnosti."

#: frontend/apps/reader/modules/readerrolling.lua:474
msgid "The current default (★) is to enable partial renderings when possible."
msgstr "Trenutno privzeto (★) je omogočeno delno izrisovanje, ko je to mogoče."

#: frontend/apps/reader/modules/readerrolling.lua:476
msgid "The current default (★) is to always do a full rendering."
msgstr "Trenutno privzeto (★) je vedno polno izrisovanje."

#: frontend/apps/reader/modules/readerrolling.lua:1540
msgid ""
"This book was first opened, and has been handled since, by an older version "
"of the rendering code.\n"
"Bookmarks and highlights can be upgraded to the latest version of the code.\n"
"\n"
"%1\n"
"\n"
"Proceed with this upgrade and reload the book?"
msgstr ""
"Ta knjiga je bila prvič odprta in od takrat upravljana s starejšo različico "
"kode za izrisovanje.\n"
"Zaznamke in poudarke lahko nadgradiš na najnovejšo različico kode.\n"
"\n"
"%1\n"
"\n"
"Želiš nadaljevati z nadgradnjo in ponovno naložiti knjigo?"

#: frontend/apps/reader/modules/readerrolling.lua:1549
msgid ""
"All your bookmarks and highlights are valid and will be available after the "
"migration."
msgstr ""
"Vsi tvoji zaznamki in poudarki so veljavni in bodo na voljo po migraciji."

#: frontend/apps/reader/modules/readerrolling.lua:1551
msgid ""
"Note that %1 (out of %2) xpaths from your bookmarks and highlights aren't "
"currently found in the book, and may have been lost. You might want to "
"toggle Rendering mode between 'legacy' and 'flat', and re-open this book, "
"and see if they are found again, before proceeding."
msgstr ""
"Upoštevaj, da %1 (od %2) poti xpath tvojih zaznamkov in poudarkov trenutno "
"ni mogoče najti v knjigi in so morda izgubljeni. Preden nadaljuješ, lahko "
"poskusiš preklopiti način izrisovanja med 'legacy' (stari) in 'flat' "
"(ploski) ter ponovno odpreti knjigo, da preveriš, če bodo spet najdeni."

#: frontend/apps/reader/modules/readerrolling.lua:1556
msgid ""
"Note that %1 (out of %2) xpaths from your bookmarks and highlights have been "
"normalized, and may not work on previous KOReader versions (if you're "
"synchronizing your reading between multiple devices, you'll need to update "
"KOReader on all of them)."
msgstr ""
"Upoštevaj, da je bilo %1 (od %2) poti xpath tvojih zaznamkov in poudarkov "
"normaliziranih in morda ne bodo delovali v prejšnjih različicah KOReaderja "
"(če branje sinhroniziraš med več napravami, boš moral posodobiti KOReader na "
"vseh)."

#: frontend/apps/reader/modules/readerrolling.lua:1571
msgid "Not now"
msgstr "Ne zdaj"

#: frontend/apps/reader/modules/readerrolling.lua:1574
msgid "Not for this book"
msgstr "Ne za to knjigo"

#: frontend/apps/reader/modules/readerrolling.lua:1578
msgid "Upgrade now"
msgstr "Nadgradi zdaj"

#: frontend/apps/reader/modules/readerrolling.lua:1590
msgid "Upgrading and reloading book…"
msgstr "Nadgrajevanje in ponovno nalaganje knjige…"

#: frontend/apps/reader/modules/readerscrolling.lua:91
msgid "Scrolling"
msgstr "Drsenje"

#: frontend/apps/reader/modules/readerscrolling.lua:102
msgid "Classic scrolling"
msgstr "Klasično drsenje"

#: frontend/apps/reader/modules/readerscrolling.lua:103
msgid "Classic scrolling will move the document with your finger."
msgstr "Pri klasičnem drsenju se dokument premika skupaj s tvojim prstom."

#: frontend/apps/reader/modules/readerscrolling.lua:116
msgid "Turbo scrolling"
msgstr "Turbo drsenje"

#: frontend/apps/reader/modules/readerscrolling.lua:117
msgid ""
"Turbo scrolling will scroll the document, at each step, by the distance from "
"your initial finger position (rather than by the distance from your previous "
"finger position).\n"
"It allows for faster scrolling without the need to lift and reposition your "
"finger."
msgstr ""
"Turbo drsenje bo dokument v vsakem koraku pomaknilo za razdaljo od začetnega "
"položaja prsta (namesto za razdaljo od prejšnjega položaja).\n"
"To omogoča hitrejše drsenje brez potrebe po dvigovanju in ponovnem "
"postavljanju prsta."

#: frontend/apps/reader/modules/readerscrolling.lua:132
msgid "On-release scrolling"
msgstr "Drsenje ob spustu"

#: frontend/apps/reader/modules/readerscrolling.lua:133
msgid ""
"On-release scrolling will scroll the document by the panned distance only on "
"finger up.\n"
"This is interesting on eInk if you only pan to better adjust page vertical "
"position."
msgstr ""
"Drsenje ob spustu bo dokument premaknilo za predeno razdaljo šele, ko "
"dvigneš prst.\n"
"To je uporabno na e-črnilu, če želiš le natančneje prilagoditi navpični "
"položaj strani."

#: frontend/apps/reader/modules/readerscrolling.lua:150
msgid "Activation delay: %1 ms"
msgstr "Zakasnitev aktivacije: %1 ms"

#: frontend/apps/reader/modules/readerscrolling.lua:157
msgid "Scroll activation delay"
msgstr "Zakasnitev aktivacije drsenja"

#: frontend/apps/reader/modules/readerscrolling.lua:158
msgid ""
"A delay can be used to avoid scrolling when swipes or multiswipes are "
"intended.\n"
"\n"
"The delay value is in milliseconds and can range from 0 to 2000 (2 "
"seconds).\n"
"Default value: %1 ms"
msgstr ""
"Zakasnitev se lahko uporabi, da preprečiš drsenje, ko želiš izvesti potege "
"ali večprstne potege.\n"
"\n"
"Vrednost zakasnitve je v milisekundah in je lahko od 0 do 2000 (2 sekundi).\n"
"Privzeta vrednost: %1 ms"

#: frontend/apps/reader/modules/readerscrolling.lua:169
#: plugins/gestures.koplugin/main.lua:708
