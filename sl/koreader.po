msgid "Dewatermark"
msgstr "Odstranjevanje vodnih žigov"

#: frontend/ui/data/koptoptions.lua:512
msgctxt "Dewatermark"
msgid "off"
msgstr "izklopljeno"

#: frontend/ui/data/koptoptions.lua:512
msgctxt "Dewatermark"
msgid "on"
msgstr "vklopljeno"

#: frontend/ui/data/koptoptions.lua:516
msgid ""
"Remove watermarks from the rendered document.\n"
"This can also be used to remove some gray background or to convert a "
"grayscale or color document to black & white and get more contrast for "
"easier reading."
msgstr ""
"Odstrani vodne žige iz izrisanega dokumenta.\n"
"To lahko uporabiš tudi za odstranjevanje sivega ozadja ali za pretvorbo "
"sivinskega ali barvnega dokumenta v črno-belega, da dobiš večji kontrast za "
"lažje branje."

